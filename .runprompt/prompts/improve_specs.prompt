#!/usr/bin/env runprompt
---
#model: openrouter/anthropic/claude-sonnet-4-20250514
model: openrouter/openai/gpt-oss-120b

tools:
  - builtin.ask_user
  - builtin.write_file('specs.md')
before:
  existing_specs: cat specs.md 2>/dev/null || echo "[No specs.md found]"
  project_name: basename $(git rev-parse --show-toplevel)
  git_log: git log --oneline -10 2>/dev/null || echo "[No commits yet]"
  git_status: git status --short
  dir_tree: find . -not -path './.git/*' -not -path './node_modules/*' -not -path './__pycache__/*' -not -path './.venv/*' -not -path './venv/*' -not -path './dist/*' -not -path './build/*' -not -path './.ruff_cache/*' -not -path './htmlcov/*' -maxdepth 3 | sort | head -80
  python_version: python3 --version 2>/dev/null || python --version 2>/dev/null || echo "[Python not found in PATH]"
  pyproject: cat pyproject.toml 2>/dev/null || echo "[No pyproject.toml]"
  requirements: cat requirements.txt 2>/dev/null || cat requirements-dev.txt 2>/dev/null || echo "[No requirements files]"
  setup_cfg: cat setup.cfg 2>/dev/null || echo "[No setup.cfg]"
  readme: cat README.md 2>/dev/null || cat README.rst 2>/dev/null || echo "[No README]"
  env_example: cat .env.example 2>/dev/null || cat .env.sample 2>/dev/null || echo "[No .env example]"
  makefile: cat Makefile 2>/dev/null || echo "[No Makefile]"
  dockerfiles: ls Dockerfile* docker-compose* 2>/dev/null || echo "[No Docker files]"
---

You are a senior Python engineer helping establish or improve a project's `specs.md` — the single source of truth for a project's goals, architecture, stack, and decisions. This file is written at project inception and updated as key decisions are made.

