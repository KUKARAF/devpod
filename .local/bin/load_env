#!/usr/bin/env bash
# Loads API credentials from the kv store and exports them as environment variables.
#
# Requirements:
#   • kv CLI (https://github.com/kukARAF/kv_cli) in PATH
#   • An active kv session (kv session check)

set -euo pipefail

if ! command -v kv &>/dev/null; then
    echo "kv: command not found — install from https://github.com/kukARAF/kv_cli" >&2
    return 1 2>/dev/null || exit 1
fi

# </dev/null ensures kv never blocks waiting for terminal input
if ! kv session check </dev/null 2>/dev/null; then
    echo "No valid kv session — skipping loading secrets." >&2
    echo "Renew with: kv session login" >&2
    return 1 2>/dev/null || exit 1
fi

# Helper: returns empty string if key not found, never blocks
_kv() { kv get "$1" </dev/null 2>/dev/null || true; }

# Anthropic
export ANTHROPIC_API_KEY="$(_kv ANTHROPIC_API_KEY)"

# OpenAI
export OPENAI_API_KEY="$(_kv OPENAI_API_KEY)"

# OpenRouter
export OPENROUTER_API_KEY="$(_kv OPENROUTER_API_KEY)"

# Google Gemini
export GEMINI_API_KEY="$(_kv GEMINI_API_KEY)"

# Cerebras
export CEREBRAS_API_KEY="$(_kv CEREBRAS_API_KEY)"

# HuggingFace
export HF_TOKEN="$(_kv HF_TOKEN)"

# Vertex AI
export VERTEXAI_PROJECT="$(_kv VERTEXAI_PROJECT)"
export VERTEXAI_LOCATION="$(_kv VERTEXAI_LOCATION)"

# Groq
export GROQ_API_KEY="$(_kv GROQ_API_KEY)"

# AWS Bedrock
export AWS_ACCESS_KEY_ID="$(_kv AWS_ACCESS_KEY_ID)"
export AWS_SECRET_ACCESS_KEY="$(_kv AWS_SECRET_ACCESS_KEY)"
export AWS_REGION="$(_kv AWS_REGION)"
export AWS_PROFILE="$(_kv AWS_PROFILE)"
export AWS_BEARER_TOKEN_BEDROCK="$(_kv AWS_BEARER_TOKEN_BEDROCK)"

# Azure OpenAI
export AZURE_OPENAI_API_ENDPOINT="$(_kv AZURE_OPENAI_API_ENDPOINT)"
export AZURE_OPENAI_API_KEY="$(_kv AZURE_OPENAI_API_KEY)"
export AZURE_OPENAI_API_VERSION="$(_kv AZURE_OPENAI_API_VERSION)"

# Jina
export JINA_API_KEY="$(_kv JINA_API_KEY)"

echo "env loaded from kv store"
