#!/usr/bin/env bash
# Loads API credentials from the kv store and exports them as environment variables.
#
# Requirements:
#   • kv CLI (https://github.com/kukARAF/kv_cli) in PATH
#   • An active kv session (kv session check)

set -euo pipefail

if ! command -v kv &>/dev/null; then
    echo "kv: command not found — install from https://github.com/kukARAF/kv_cli" >&2
    return 1 2>/dev/null || exit 1
fi

# </dev/null ensures kv never blocks waiting for terminal input
if ! kv session check </dev/null 2>/dev/null; then
    echo "No valid kv session — skipping loading secrets." >&2
    echo "Renew with: kv session login" >&2
    return 1 2>/dev/null || exit 1
fi

# Only export if kv returns a non-empty value — variable is left unset otherwise
_kv_export() {
    local key="$1" val
    val="$(kv get "$key" </dev/null 2>/dev/null)" || true
    [[ -n "$val" ]] && export "$key=$val"
}

_kv_export ANTHROPIC_API_KEY
_kv_export OPENAI_API_KEY
_kv_export OPENROUTER_API_KEY
_kv_export GEMINI_API_KEY
_kv_export CEREBRAS_API_KEY
_kv_export HF_TOKEN
_kv_export VERTEXAI_PROJECT
_kv_export VERTEXAI_LOCATION
_kv_export GROQ_API_KEY
_kv_export AWS_ACCESS_KEY_ID
_kv_export AWS_SECRET_ACCESS_KEY
_kv_export AWS_REGION
_kv_export AWS_PROFILE
_kv_export AWS_BEARER_TOKEN_BEDROCK
_kv_export AZURE_OPENAI_API_ENDPOINT
_kv_export AZURE_OPENAI_API_KEY
_kv_export AZURE_OPENAI_API_VERSION
_kv_export JINA_API_KEY

echo "env loaded from kv store"
